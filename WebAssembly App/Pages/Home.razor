@page "/"
@using CloudFileManager.Models
@using WebAssembly_App.Shared
@using System.Net
@using Microsoft.AspNetCore.Components
@using System.Linq

<PageTitle>檔案管理系統</PageTitle>

<div class="container py-4">
    <h2 class="mb-4">☁️ 雲端檔案管理系統</h2>

    <div class="row mb-2">
        <div class="col">
            <!-- 包在方框內的工具列 -->
            <div class="toolbar-box mb-2">
                <div class="btn-toolbar align-items-center" role="toolbar" aria-label="toolbar">

                    <div class="btn-group" role="group" aria-label="undo-redo">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="Undo" disabled="@(!_undo.Any())" title="撤銷">
                            ↶ 撤銷
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="Redo" disabled="@(!_redo.Any())" title="重做">
                             ↷ 重做
                        </button>
                    </div>

                    <div class="toolbar-divider" aria-hidden="true"></div>

                    <div class="btn-group" role="group" aria-label="clipboard">
                        <span class="toolbar-emoji" aria-hidden="true">📃</span>
                        <button class="btn btn-sm btn-outline-primary" @onclick="Copy" title="複製">
                            @((MarkupString)IconLibrary.Copy) 複製
                        </button>
                        <button class="btn btn-sm btn-outline-primary" @onclick="Paste" title="貼上" disabled="@(clipboardItem == null)">
                            @((MarkupString)IconLibrary.Paste) 貼上
                        </button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected" title="刪除" disabled="@(selectedItem == null)">
                            @((MarkupString)IconLibrary.Trash) 刪除
                        </button>
                    </div>

                    <div class="toolbar-divider" aria-hidden="true"></div>

                    <div class="btn-group" role="group" aria-label="sort">
                        <span class="toolbar-emoji" aria-hidden="true">↕️</span>
                        <button class="btn btn-sm @(IsActiveSort(SortKey.Name) ? "btn-primary text-white" : "btn-outline-secondary")"
                                @onclick="() => SortSelected(SortKey.Name, !IsActiveSort(SortKey.Name) ? true : !IsActiveSortAsc())">
                            @if (IsActiveSort(SortKey.Name))
                            {
                                <span class="sort-arrow">@(IsActiveSortAsc() ? "▲" : "▼")</span>
                            }
                            名稱
                        </button>

                        <button class="btn btn-sm @(IsActiveSort(SortKey.Size) ? "btn-primary text-white" : "btn-outline-secondary")"
                                @onclick="() => SortSelected(SortKey.Size, !IsActiveSort(SortKey.Size) ? true : !IsActiveSortAsc())">
                            @if (IsActiveSort(SortKey.Size))
                            {
                                <span class="sort-arrow">@(IsActiveSortAsc() ? "▲" : "▼")</span>
                            }
                            大小
                        </button>

                        <button class="btn btn-sm @(IsActiveSort(SortKey.Extension) ? "btn-primary text-white" : "btn-outline-secondary")"
                                @onclick="() => SortSelected(SortKey.Extension, !IsActiveSort(SortKey.Extension) ? true : !IsActiveSortAsc())">
                            @if (IsActiveSort(SortKey.Extension))
                            {
                                <span class="sort-arrow">@(IsActiveSortAsc() ? "▲" : "▼")</span>
                            }
                            類型
                        </button>
                    </div>

                    <div class="btn-group ms-2" role="group" aria-label="tags">
                        <span class="toolbar-emoji" aria-hidden="true">🏷️</span>
                        <button class="btn btn-sm btn-outline-danger" @onclick='() => ToggleTagOnSelected("Urgent")' disabled="@(selectedItem == null)">
                            @((MarkupString)IconLibrary.Label) Urgent
                            <span class="badge bg-danger ms-2">@CountTag("Urgent")</span>
                        </button>
                        <button class="btn btn-sm btn-outline-primary" @onclick='() => ToggleTagOnSelected("Work")' disabled="@(selectedItem == null)">
                            @((MarkupString)IconLibrary.Label) Work
                            <span class="badge bg-primary ms-2">@CountTag("Work")</span>
                        </button>
                        <button class="btn btn-sm btn-outline-success" @onclick='() => ToggleTagOnSelected("Personal")' disabled="@(selectedItem == null)">
                            @((MarkupString)IconLibrary.Label) Personal
                            <span class="badge bg-success ms-2">@CountTag("Personal")</span>
                        </button>
                    </div>

                </div>
            </div>
            <!-- end toolbar-box -->
        </div>
    </div>

    <div class="row">
        <div class="col-12 col-ratio-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">目錄結構</div>
                <div class="card-body">
                    <FileNode Items="rootItems"
                              SelectedItem="selectedItem"
                              ExpandedItems="_expandedFolders"
                              HighlightedItems="_matchedItems"
                              OnSelect="OnSelectItem" />
                </div>
            </div>
        </div>

        <div class="col-12 col-ratio-7">
            <div class="card shadow-sm border-primary h-auto">
                <div class="card-body">
                    <h5>系統操作</h5>
                    @* 按鈕改成執行中禁用，避免重複觸發 *@
                    <button class="btn btn-outline-primary w-100 mb-2" @onclick="RunSizeCalc" disabled="@_isTraversing">⚡ 計算總大小</button>

                    <div class="d-grid mb-2">
                        <button class="btn btn-outline-success" @onclick="RunExportXml" disabled="@_isTraversing">📄 匯出 XML</button>
                    </div>
                    <div class="input-group mb-2">
                        <input type="text" class="form-control" placeholder=".docx" @bind="searchExt" />
                        <button class="btn btn-outline-secondary" @onclick="RunSearch" disabled="@_isTraversing">🔍 副檔名搜尋</button>
                    </div>


                    @* 小型監控視窗：放在 Console 前面 *@
                    <div class="p-2 bg-light rounded border mb-2" style="font-size: 0.9rem;">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <div class="fw-semibold">📡 監控 (Observer)</div>
                            @if (_isTraversing)
                            {
                                <span class="badge bg-primary">LIVE</span>
                            }
                        </div>

                        <div class="small text-muted">目前節點</div>
                        <div class="fw-semibold text-primary text-truncate mb-1">@_currentNode</div>

                        <div class="d-flex justify-content-between small mb-1">
                            <span>探訪進度</span>
                            <span>@_progressPercent%</span>
                        </div>

                        <div class="progress" style="height: 6px;" role="progressbar" aria-valuenow="@_progressPercent" aria-valuemin="0" aria-valuemax="100">
                            <div class="progress-bar" style="width:@($"{_progressPercent}%")"></div>
                        </div>

                        <div class="text-end small text-muted mt-1">@_visitedNodes/@_totalNodes Nodes</div>
                    </div>

                    <div class="p-3 bg-light rounded console-box">
                        <div class="console-header">
                            <span class="console-dot" aria-hidden="true">●</span>
                            <span class="console-title">CONSOLE</span>
                        </div>
                        <div class="console-output">@((MarkupString)consoleOutput)</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
