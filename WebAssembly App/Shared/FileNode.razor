@using CloudFileManager.Models

<ul class="list-unstyled ms-4 border-start ps-3">
    @foreach (var item in Items)
    {
        <li class="my-2">
            @if (item is Folder folder)
            {
                <div class="d-flex align-items-center">
                    <button class="btn btn-sm btn-link p-0 me-2" @onclick="() => Toggle(folder)" aria-expanded="@IsExpanded(folder)">
                        @(IsExpanded(folder) ? "▾" : "▸")
                    </button>
                    <span class="fw-bold text-primary"
                          @onclick="() => SelectItem(folder)"
                          style="cursor:pointer;@GetNodeStyle(folder)">
                        📁 @folder.Name
                    </span>

                    @if (folder.Tags?.Count > 0)
                    {
                        <div class="ms-2">
                            @foreach (var t in folder.Tags)
                            {
                                <span class="@GetTagBadgeClass(t) me-1">@t</span>
                            }
                        </div>
                    }
                </div>

                @if (IsExpanded(folder))
                {
                    <FileNode Items="folder.Children"
                              SelectedItem="SelectedItem"
                              ExpandedItems="ExpandedItems"
                              HighlightedItems="HighlightedItems"
                              OnSelect="OnSelect" />
                }
            }
            else
            {
                <div class="d-flex align-items-center">
                    <span class="me-2">
                        @if (item is WordFile) { <span class="text-primary">📄</span> }
                        else if (item is ImageFile) { <span class="text-info">🖼️</span> }
                        else { <span class="text-secondary">📄</span> }
                    </span>
                    <div style="min-width:0; width:100%;">
                        <div class="d-flex align-items-center">
                            <div class="fw-bold text-truncate"
                                 style="max-width:220px; cursor:pointer;@GetNodeStyle(item)"
                                 @onclick="() => SelectItem(item)">
                                @item.Name
                            </div>

                            <div class="ms-2 small text-muted">
                                (@item.SizeKB KB |
                                @if (item is WordFile w) { <span>pages: @w.PageCount</span> }
                                else if (item is ImageFile i) { <span>res: @i.Width x @i.Height</span> }
                                else if (item is TextFile t) { <span>enc: @t.Encoding</span> })
                            </div>
                        </div>

                        @if (item.Tags?.Count > 0)
                        {
                            <div class="mt-1">
                                @foreach (var tag in item.Tags)
                                {
                                    <span class="@GetTagBadgeClass(tag) me-1">@tag</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </li>
    }
</ul>

@code {
    [Parameter] public List<FileSystemItem> Items { get; set; } = new();
    [Parameter] public FileSystemItem? SelectedItem { get; set; }
    [Parameter] public EventCallback<FileSystemItem?> OnSelect { get; set; }
    [Parameter] public HashSet<FileSystemItem>? ExpandedItems { get; set; }

    // 新增：搜尋命中高亮集合
    [Parameter] public HashSet<FileSystemItem>? HighlightedItems { get; set; }

    private readonly HashSet<FileSystemItem> _localExpanded = new();
    private HashSet<FileSystemItem> ExpandedSet => ExpandedItems ?? _localExpanded;

    private void Toggle(FileSystemItem folder)
    {
        if (!ExpandedSet.Remove(folder))
        {
            ExpandedSet.Add(folder);
        }
    }

    private bool IsExpanded(FileSystemItem folder) => ExpandedSet.Contains(folder);

    private void SelectItem(FileSystemItem? item)
    {
        if (item is null) return;
        SelectedItem = item;
        OnSelect.InvokeAsync(item);
    }

    private bool IsSelected(FileSystemItem item) => SelectedItem != null && ReferenceEquals(SelectedItem, item);

    private bool IsHighlighted(FileSystemItem item) => HighlightedItems?.Contains(item) == true;

    private string GetNodeStyle(FileSystemItem item)
    {
        if (IsSelected(item)) return "background:#e9f5ff;padding:2px 6px;border-radius:4px;";
        if (IsHighlighted(item)) return "background:#fff3cd;padding:2px 6px;border-radius:4px;";
        return "";
    }

    private string GetTagBadgeClass(string tag)
    {
        if (string.IsNullOrWhiteSpace(tag)) return "badge bg-secondary";
        return tag.Trim().ToLower() switch
        {
            "urgent" => "badge bg-danger text-white",
            "work" => "badge bg-primary text-white",
            "personal" => "badge bg-success text-white",
            _ => "badge bg-secondary"
        };
    }
}